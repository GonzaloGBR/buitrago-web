# MySQL / phpMyAdmin. Copia a .env.local (Next.js) y/o .env (herramientas).
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:3306/NOMBRE_BASE
#
# Prisma: npm run db:push carga .env + .env.local (dotenv -c).
DATABASE_URL="mysql://user:password@localhost:3306/buitrago"

# Panel /admin — contraseña de acceso y firma de sesión (mín. 16 caracteres).
ADMIN_PASSWORD="cambia-esto-por-una-contraseña-larga"
ADMIN_SESSION_SECRET="genera-una-cadena-aleatoria-minimo-16-caracteres"

